{
  "mcpServers": {
    "caddy_mcp": {
      "command": "python",
      "args": [
        "-m",
        "caddy_mcp.mcp_server"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "CADDY_MCP_BASE_URL": "http://localhost:2019",
        "CADDY_MCP_PASSWORD": "",
        "CADDY_MCP_USERNAME": "",
        "CADDY_TOKEN": "your_secure_bearer_token",
        "CADDY_URL": "http://localhost:2019",
        "CONFIGTOOL": "true"
      }
    }
  }
}
