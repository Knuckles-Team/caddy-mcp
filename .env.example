# Caddy Administration API URL endpoint
CADDY_URL=http://localhost:2019
# Optional bearer token if API is secured
CADDY_TOKEN=your_secure_bearer_token
# Alternate Caddy Admin API URL (fallback when CADDY_URL is unset)
CADDY_MCP_BASE_URL=http://localhost:2019
# Basic-auth username for the Caddy Admin API
CADDY_MCP_USERNAME=
# Basic-auth password for the Caddy Admin API
CADDY_MCP_PASSWORD=
# Verify TLS certificates when calling the Caddy Admin API
CADDY_MCP_SSL_VERIFY=true
# Toggle the Caddy config / debug / PKI / reverse-proxy tools
CONFIGTOOL=true
